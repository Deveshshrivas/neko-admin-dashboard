    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst conversation = body.conversation || {};\nconst message = body.message || {};\nconst recipient = body.recipient || {};\nconst text = String(body.text || message.content_text || '').trim();\n\nif (!text) throw new Error('Missing dashboard reply text');\nif (!conversation.id) throw new Error('Missing conversation.id');\nif (!conversation.channel_account_id) throw new Error('Missing conversation.channel_account_id');\n\nreturn [{\n  json: {\n    source: 'dashboard',\n    event: body.event || 'human_reply',\n    status: body.status || conversation.status || '',\n    conversation_id: conversation.id,\n    customer_id: conversation.customer_id || recipient.customer_id || null,\n    channel_account_id: conversation.channel_account_id,\n    branch_id: conversation.branch_id || null,\n    sender_wa_phone: recipient.whatsapp_phone || body.sender_wa_phone || body.customer?.phone || '',\n    phone_number_id: body.phone_number_id || body.channel_account?.external_id || '',\n    content_text: text,\n    created_at: new Date().toISOString(),\n  }\n}];"
      },
      "id": "241fb8e4-4549-4cd5-9013-f75c72f8e095",
      "name": "2. Code: Normalize Dashboard Payload",
      "type": "n8n-nodes-base.code",
