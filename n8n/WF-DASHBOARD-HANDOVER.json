            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ conversation_id: $json.conversation_id, channel_account_id: $json.channel_account_id, channel: 'whatsapp', role: 'employee', direction: 'outbound', message_type: 'text', content_text: $json.content_text, content_media_url: null, external_message_id: null, processing_status: 'processing', metadata: { source: 'admin_dashboard', dispatch: { sender_wa_phone: $json.sender_wa_phone, phone_number_id: $json.phone_number_id, message_type: 'text', body: $json.content_text } } }) }}",
        "options": {
          "timeout": 5000
        }
      },
      "id": "47dbd2a4-4a4f-4e67-b445-b70269166c14",
